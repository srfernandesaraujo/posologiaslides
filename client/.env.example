# Config do app Web do Firebase — Firebase Console > Configurações do projeto >
# General > "Your apps" > app Web > SDK setup and configuration. Não é secreta.
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="seu-projeto-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="seu-projeto-id"
VITE_FIREBASE_STORAGE_BUCKET="seu-projeto-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx"

# URL completa do backend (server/), sem barra no final. Deixe em branco em
# dev local — o proxy do Vite (vite.config.js) já redireciona /api e
# /socket.io para http://localhost:3001. Em produção (ex. Cloudflare Pages),
# aponte para a URL pública do server no Render.
VITE_API_URL="https://seu-servico.onrender.com"
