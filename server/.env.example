# Firebase Admin SDK — extraia esses 3 valores do JSON baixado em:
# Firebase Console > Configurações do projeto > Service accounts > Generate new private key
FIREBASE_PROJECT_ID="seu-projeto-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com"
# Cole a private_key do JSON exatamente como veio, entre aspas (as quebras de linha "\n" ficam escapadas mesmo)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"
# Bucket do Cloud Storage — mesmo valor de VITE_FIREBASE_STORAGE_BUCKET no
# client/.env (Firebase Console > Storage, ou Configurações do projeto > General).
FIREBASE_STORAGE_BUCKET="seu-projeto-id.appspot.com"

# Origem do frontend (para CORS). Em dev local: http://localhost:5173
# Em produção: a URL do site no Cloudflare Pages, sem barra no final
# (ex. https://posologiaslides.pages.dev ou seu domínio customizado).
CLIENT_URL="http://localhost:5173"

PORT=3001
